# =============================================================================
# KBase Docker Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Docker Registry ---
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
IMAGE_TAG=main

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password

# Khi dùng RDS thay vì container PostgreSQL local, đặt:
# DB_HOST=your-rds-endpoint.amazonaws.com
# Mặc định là "postgres" (tên container)
# DB_HOST=postgres

# --- JWT ---
JWT_SECRET=your_jwt_secret_key

# --- AWS ---
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=kbase-storage-bucket
AWS_SQS_USER_EVENTS_QUEUE_URL=https://sqs.ap-southeast-2.amazonaws.com/ACCOUNT_ID/kbase-queue
AWS_SQS_ACTIVTY_EVENTS_QUEUE_URL=https://sqs.ap-southeast-2.amazonaws.com/ACCOUNT_ID/kbase-activity-queue
